# Скопируйте на сервер, подставьте домен, включите симлинк в sites-enabled.
# Пример пути: /etc/nginx/sites-available/septus
#
# certbot --nginx -d example.ru -d www.example.ru
# Certbot сам допишет ssl_* директивы в этот server { } или создаст отдельный файл.

upstream septus_next {
    server 127.0.0.1:3002;
    keepalive 64;
}

server {
    listen 80;
    listen [::]:80;
    server_name ЗАМЕНИТЕ_НА_ВАШ_ДОМЕН www.ЗАМЕНИТЕ_НА_ВАШ_ДОМЕН;

    location /.well-known/acme-challenge/ {
        root /var/www/html;
    }

    location / {
        proxy_pass http://septus_next;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_read_timeout 60s;
    }
}
