{
  "name": "septon",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/prepare-catalog-assets.js",
    "dev": "next dev -p 3002",
    "prebuild": "node scripts/prepare-catalog-assets.js",
    "build": "npm run build:studio && next build",
    "build:app": "next build",
    "build:static": "npm run prebuild && set NEXT_OUTPUT=export&& next build",
    "build:studio": "sanity build public/admin --yes && node scripts/fix-sanity-admin-assets.js public/admin",
    "build:all": "npm run build",
    "export": "npm run build:static",
    "start": "next start -p 3002",
    "lint": "next lint",
    "studio": "sanity dev --port 3333"
  },
  "dependencies": {
    "@formkit/auto-animate": "^0.9.0",
    "@headlessui/react": "^2.2.9",
    "@heroicons/react": "^2.2.0",
    "@sanity/client": "^7.22.0",
    "@sanity/image-url": "^2.1.1",
    "@sanity/vision": "^3.99.0",
    "axios": "^1.6.0",
    "framer-motion": "^12.38.0",
    "mammoth": "^1.6.0",
    "next": "^15.2.0",
    "next-sanity": "^9.12.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.45.3",
    "react-icons": "^5.6.0",
    "sanity": "^3.99.0",
    "styled-components": "^6.4.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.0.0"
  }
}
